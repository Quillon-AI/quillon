PORT=3001
JWT_SECRET=change-me-to-random-string
ADMIN_USER=admin
ADMIN_PASS_HASH=$2a$10$...
QUILLON_PUBLIC_PATH=/var/www/quillon.ru/content
QUILLON_TECH_PATH=/var/www/tech.quillon.ru/content

# Blog database
DATABASE_URL=postgresql://user:password@localhost:5432/quillon

# Claude (через quillon-video-pipeline вместо прямого Anthropic API)
CLAUDE_PIPELINE_URL=https://video.quillon.ru
CLAUDE_PIPELINE_SECRET=

# S3 — Selectel
S3_ENDPOINT=https://s3.ru-3.storage.selcloud.ru
S3_REGION=ru-3
S3_BUCKET=quillon
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE=https://<container-id>.selstorage.ru
S3_KEY_PREFIX=blog

# IndexNow (https://www.indexnow.org/getkey)
INDEXNOW_KEY=

# Recraft AI — cover image generation for blog
RECRAFT_API_KEY=
